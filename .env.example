# Copy to .env and adjust. All vars are optional; sensible defaults apply.

# CAGEMATCH_BASE_URL=https://www.cagematch.net
# CAGEMATCH_HEADLESS=true
# CAGEMATCH_CHANNEL=chromium          # or "chrome" for max stealth (needs Chrome installed)
# CAGEMATCH_CONCURRENCY=2
# CAGEMATCH_REQUEST_DELAY=1.5
# CAGEMATCH_NAV_TIMEOUT_MS=30000
# CAGEMATCH_OUTPUT_DIR=data
# CAGEMATCH_USER_DATA_DIR=            # set to reuse a persistent browser profile/cookies

# Proxy (room for routing through an upstream/rotating proxy):
# CAGEMATCH_PROXY_SERVER=http://proxy.example.com:8080
# CAGEMATCH_PROXY_USERNAME=
# CAGEMATCH_PROXY_PASSWORD=
# CAGEMATCH_PROXY_BYPASS=
