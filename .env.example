# Copy to .env and adjust. All vars are optional; sensible defaults apply.

# CAGEMATCH_BASE_URL=https://www.cagematch.net
# CAGEMATCH_HEADLESS=true
# CAGEMATCH_CHANNEL=chromium          # or "chrome" for max stealth (needs Chrome installed)
# CAGEMATCH_CONCURRENCY=2
# CAGEMATCH_REQUEST_DELAY_MIN=0.8
# CAGEMATCH_REQUEST_DELAY_MAX=1.2
# CAGEMATCH_NAV_TIMEOUT_MS=30000
# CAGEMATCH_OUTPUT_DIR=data
# CAGEMATCH_USER_DATA_DIR=            # set to reuse a persistent browser profile/cookies
# CAGEMATCH_BLOCK_RESOURCES=true      # abort image/media/font/stylesheet requests to save bandwidth

# Proxy (room for routing through an upstream/rotating proxy):
# CAGEMATCH_PROXY_SERVER=http://proxy.example.com:8080
# CAGEMATCH_PROXY_USERNAME=
# CAGEMATCH_PROXY_PASSWORD=
# CAGEMATCH_PROXY_BYPASS=

# Proxy pool (alternative to the single CAGEMATCH_PROXY_* vars above): a file with one
# USERNAME:PASSWORD@HOST:PORT per line. Ignored if CAGEMATCH_PROXY_SERVER is set. Each
# hybrid session uses the next base credential and appends Proxy-Cheap's
# `_session-<random>_ttl-<minutes>` suffix so patchright + httpx share one exit IP.
# CAGEMATCH_PROXY_LIST_FILE=proxy-creds.txt
# CAGEMATCH_PROXY_SESSION_MAX_REQUESTS=100
# CAGEMATCH_PROXY_SESSION_TTL_MINUTES=10

# Legacy static-proxy fallback when neither CAGEMATCH_PROXY_* nor the pool is configured.
# CAGEMATCH_STATIC_PROXY=
